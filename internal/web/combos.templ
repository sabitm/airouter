package web

import (
	"strconv"

	"airouter/internal/domain"
)

templ CombosPage(combos []*domain.Combo, providers []*domain.Provider) {
	@Layout("Combos", "/dashboard/combos") {
		<section class="panel">
			<h1>Combos</h1>
			<p class="hint">A custom model name clients call (e.g. "default"), backed by one or more provider + upstream-model targets. With multiple targets, the strategy picks which to use: failover tries them in order, round-robin spreads load and still fails over.</p>
			if len(providers) == 0 {
				<p class="empty">Add a provider first.</p>
			} else {
				@comboForm(providers)
			}
		</section>
		<section class="panel">
			@ComboList(combos)
		</section>
	}
}

templ comboForm(providers []*domain.Provider) {
	<form class="combo-form" hx-post="/dashboard/combos" hx-target="#combo-list" hx-swap="outerHTML" hx-on::after-request="if(event.detail.successful &amp;&amp; event.detail.elt === this) this.reset()">
		<div class="row-form">
			<input name="name" placeholder="combo name (e.g. default)" required/>
			@strategySelect("")
		</div>
		<div class="targets">
			@comboTargetRow("add-0", providers, 0, "")
		</div>
		@targetTemplate(providers)
		<div class="row-form">
			<button type="button" class="link" onclick="addComboTarget(this)">+ Add target</button>
			<button type="submit">Add combo</button>
		</div>
	</form>
}

templ strategySelect(selected domain.ComboStrategy) {
	<select name="strategy" title="selection strategy">
		if selected == domain.StrategyRoundRobin {
			<option value="failover">failover</option>
			<option value="roundrobin" selected>round-robin</option>
		} else {
			<option value="failover" selected>failover</option>
			<option value="roundrobin">round-robin</option>
		}
	</select>
}

// comboTargetRow renders one provider + upstream-model pair. uid must be unique
// on the page so the datalist id and the htmx model-fetch target do not collide
// across rows or across open forms.
templ comboTargetRow(uid string, providers []*domain.Provider, selectedProviderID int64, model string) {
	{{ listID := "model-options-" + uid }}
	<div class="target-row row-form">
		<select name="provider_id" hx-get={ "/dashboard/providers/models?list=" + listID } hx-trigger="change, load" hx-target={ "#model-options-wrap-" + uid } hx-swap="innerHTML">
			for _, p := range providers {
				if p.ID == selectedProviderID {
					<option value={ strconv.FormatInt(p.ID, 10) } selected>{ p.Name } ({ string(p.Protocol) })</option>
				} else {
					<option value={ strconv.FormatInt(p.ID, 10) }>{ p.Name } ({ string(p.Protocol) })</option>
				}
			}
		</select>
		<input name="upstream_model" list={ listID } value={ model } placeholder="upstream model id (e.g. gpt-4o)" required/>
		<span id={ "model-options-wrap-" + uid }>@ModelDatalist(nil, listID)</span>
		<button type="button" class="link danger" onclick="removeComboTarget(this)" title="remove target">x</button>
	</div>
}

// targetTemplate holds an inert prototype target row whose __IDX__ placeholders
// addComboTarget() rewrites to a unique index when cloning. Rendered with no
// selected provider so a fresh row starts blank. The <template> content is inert
// so htmx does not wire it until it is cloned into the form.
templ targetTemplate(providers []*domain.Provider) {
	<template class="target-template">
		@comboTargetRow("__IDX__", providers, 0, "")
	</template>
}

// ModelDatalist backs an upstream_model input's autocomplete with models
// fetched live from the selected provider. An empty list just yields no
// suggestions; the field stays free-text. listID must be unique per page, so
// the add form and each open edit row use distinct ids.
templ ModelDatalist(models []string, listID string) {
	<datalist id={ listID }>
		for _, m := range models {
			<option value={ m }></option>
		}
	</datalist>
}

templ ComboList(combos []*domain.Combo) {
	<div id="combo-list">
		if len(combos) == 0 {
			<p class="empty">No combos yet.</p>
		} else {
			<table>
				<thead>
					<tr><th>Combo</th><th>Strategy</th><th>Targets</th><th></th></tr>
				</thead>
				<tbody>
					for _, c := range combos {
						@ComboRow(c)
					}
				</tbody>
			</table>
		}
	</div>
}

templ ComboRow(c *domain.Combo) {
	<tr id={ "combo-" + strconv.FormatInt(c.ID, 10) }>
		<td class="mono">{ c.Name }</td>
		<td>
			if len(c.Targets) > 1 {
				<span class="tag">{ strategyLabel(c.Strategy) }</span>
			} else {
				<span class="muted">single</span>
			}
		</td>
		<td>
			<ul class="target-list">
				for _, t := range c.Targets {
					<li>
						{ t.Provider.Name }
						<span class="tag">{ string(t.Provider.Protocol) }</span>
						<span class="mono">{ t.UpstreamModel }</span>
					</li>
				}
			</ul>
		</td>
		<td class="actions">
			<button class="link" hx-get={ "/dashboard/combos/" + strconv.FormatInt(c.ID, 10) + "/edit" } hx-target={ "#combo-" + strconv.FormatInt(c.ID, 10) } hx-swap="outerHTML">Edit</button>
			<button class="link danger" hx-post={ "/dashboard/combos/" + strconv.FormatInt(c.ID, 10) + "/delete" } hx-target="#combo-list" hx-swap="outerHTML" hx-confirm="Delete this combo?">Delete</button>
		</td>
	</tr>
}

func strategyLabel(s domain.ComboStrategy) string {
	if s == domain.StrategyRoundRobin {
		return "round-robin"
	}
	return "failover"
}

templ ComboEditRow(c *domain.Combo, providers []*domain.Provider) {
	{{ id := strconv.FormatInt(c.ID, 10) }}
	<tr id={ "combo-" + id }>
		<td colspan="4">
			<form class="combo-form" hx-post={ "/dashboard/combos/" + id } hx-target="#combo-list" hx-swap="outerHTML">
				<div class="row-form">
					<input name="name" value={ c.Name } required/>
					@strategySelect(c.Strategy)
				</div>
				<div class="targets">
					for i, t := range c.Targets {
						@comboTargetRow("edit-"+id+"-"+strconv.Itoa(i), providers, t.ProviderID, t.UpstreamModel)
					}
				</div>
				@targetTemplate(providers)
				<div class="row-form">
					<button type="button" class="link" onclick="addComboTarget(this)">+ Add target</button>
					<button type="submit">Save</button>
					<button type="button" class="link" hx-get={ "/dashboard/combos/" + id + "/row" } hx-target={ "#combo-" + id } hx-swap="outerHTML">Cancel</button>
				</div>
			</form>
		</td>
	</tr>
}
