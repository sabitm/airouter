package web

import (
	"strconv"

	"airouter/internal/domain"
)

templ ProvidersPage(providers []*domain.Provider, baseURL string) {
	@Layout("Providers", "/dashboard/providers") {
		@ConnectionPanel(baseURL)
		<section class="panel">
			<h1>Providers</h1>
			<p class="hint">An upstream connection: a base URL, an API key, and the protocol it speaks.</p>
			@providerForm()
		</section>
		<section class="panel">
			@ProviderList(providers)
		</section>
	}
}

// ConnectionPanel shows the router's own ingress URLs for agent clients. The two
// differ by design: the Anthropic SDK appends /v1/messages to its base URL, so
// it must omit /v1; OpenAI clients append /chat/completions to a base that
// already ends in /v1.
templ ConnectionPanel(baseURL string) {
	<section class="panel">
		<h1>Connect an agent</h1>
		<p class="hint">Point your agent at the router using its access key as the API key.</p>
		<div class="conn-row">
			<label>Claude Code (ANTHROPIC_BASE_URL)</label>
			<input class="mono conn-url" readonly value={ baseURL }/>
			<button type="button" class="link" onclick="navigator.clipboard.writeText(this.previousElementSibling.value)">Copy</button>
		</div>
		<div class="conn-row">
			<label>Codex (OPENAI_BASE_URL)</label>
			<input class="mono conn-url" readonly value={ baseURL + "/v1" }/>
			<button type="button" class="link" onclick="navigator.clipboard.writeText(this.previousElementSibling.value)">Copy</button>
		</div>
	</section>
}

templ providerForm() {
	<form class="row-form" hx-post="/dashboard/providers" hx-target="#provider-list" hx-swap="outerHTML" hx-on::after-request="if(event.detail.successful &amp;&amp; event.detail.elt === this) this.reset()">
		<input name="name" placeholder="name (e.g. openrouter)" required/>
		<input name="base_url" placeholder="https://api.example.com/v1" required/>
		<input name="api_key" type="password" placeholder="api key" required/>
		<select name="protocol">
			<option value="openai">openai</option>
			<option value="anthropic">anthropic</option>
		</select>
		<select name="auth_scheme" title="credential header">
			<option value="">default</option>
			<option value="bearer">bearer</option>
			<option value="x-api-key">x-api-key</option>
		</select>
		<button type="button" class="link" hx-post="/dashboard/providers/check" hx-include="closest form" hx-target="next .check-result" hx-swap="innerHTML" hx-indicator="next .check-indicator">Check</button>
		<span class="check-indicator htmx-indicator">checking...</span>
		<button type="submit">Add</button>
		<span class="check-result"></span>
	</form>
}

// CheckResult reports the outcome of a connectivity check inline.
templ CheckResult(ok bool, msg string) {
	if ok {
		<span class="check ok">{ msg }</span>
	} else {
		<span class="check err">{ msg }</span>
	}
}

templ ProviderList(providers []*domain.Provider) {
	<div id="provider-list">
		if len(providers) == 0 {
			<p class="empty">No providers yet.</p>
		} else {
			<table>
				<thead>
					<tr><th>Name</th><th>Base URL</th><th>API key</th><th>Protocol</th><th>Auth</th><th></th></tr>
				</thead>
				<tbody>
					for _, p := range providers {
						@ProviderRow(p)
					}
				</tbody>
			</table>
		}
	</div>
}

templ ProviderRow(p *domain.Provider) {
	<tr id={ "provider-" + strconv.FormatInt(p.ID, 10) }>
		<td>{ p.Name }</td>
		<td class="mono">{ p.BaseURL }</td>
		<td class="mono">{ maskKey(p.APIKey) }</td>
		<td>{ string(p.Protocol) }</td>
		<td>{ string(p.Auth()) }</td>
		<td class="actions">
			<button class="link" hx-get={ "/dashboard/providers/" + strconv.FormatInt(p.ID, 10) + "/edit" } hx-target={ "#provider-" + strconv.FormatInt(p.ID, 10) } hx-swap="outerHTML">Edit</button>
			<button class="link danger" hx-post={ "/dashboard/providers/" + strconv.FormatInt(p.ID, 10) + "/delete" } hx-target="#provider-list" hx-swap="outerHTML" hx-confirm="Delete this provider and its combos?">Delete</button>
		</td>
	</tr>
}

templ ProviderEditRow(p *domain.Provider) {
	<tr id={ "provider-" + strconv.FormatInt(p.ID, 10) }>
		<td colspan="6">
			<form class="row-form" hx-post={ "/dashboard/providers/" + strconv.FormatInt(p.ID, 10) } hx-target="#provider-list" hx-swap="outerHTML">
				<input type="hidden" name="id" value={ strconv.FormatInt(p.ID, 10) }/>
				<input name="name" value={ p.Name } required/>
				<input name="base_url" value={ p.BaseURL } required/>
				<input name="api_key" type="password" placeholder="leave blank to keep current"/>
				<select name="protocol">
					if p.Protocol == domain.ProtocolOpenAI {
						<option value="openai" selected>openai</option>
						<option value="anthropic">anthropic</option>
					} else {
						<option value="openai">openai</option>
						<option value="anthropic" selected>anthropic</option>
					}
				</select>
				<select name="auth_scheme" title="credential header">
					if p.Auth() == domain.AuthBearer {
						<option value="bearer" selected>bearer</option>
						<option value="x-api-key">x-api-key</option>
					} else {
						<option value="bearer">bearer</option>
						<option value="x-api-key" selected>x-api-key</option>
					}
				</select>
				<button type="button" class="link" hx-post="/dashboard/providers/check" hx-include="closest form" hx-target="next .check-result" hx-swap="innerHTML" hx-indicator="next .check-indicator">Check</button>
				<span class="check-indicator htmx-indicator">checking...</span>
				<button type="submit">Save</button>
				<button type="button" class="link" hx-get={ "/dashboard/providers/" + strconv.FormatInt(p.ID, 10) + "/row" } hx-target={ "#provider-" + strconv.FormatInt(p.ID, 10) } hx-swap="outerHTML">Cancel</button>
				<span class="check-result"></span>
			</form>
		</td>
	</tr>
}
